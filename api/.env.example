# =============================================================================
# Event API — vzorová konfigurácia
#
#   cp .env.example .env && php artisan key:generate
#
# Prázdne hodnoty sú tajomstvá — doplň ich lokálne, nikdy ich necommituj.
#
# NA PRODUKCII nastav:  APP_ENV=production, APP_DEBUG=false, LOG_LEVEL=warning
# =============================================================================

APP_NAME=Event
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://event-api.local

# Adresa SPA (ui/). Používa sa v e-mailoch na stavbu odkazov späť do aplikácie.
FRONTEND_URL=http://localhost:5173

# Platnosť overovacieho odkazu z registračného e-mailu (v hodinách).
REGISTRATION_VERIFICATION_TTL_HOURS=48

# Token pre webcron endpoint GET /cron/schedule-run?token=...
# Hosting nemá shell cron, scheduler spúšťa externá služba cez URL.
# Vygeneruj napr.: php -r "echo bin2hex(random_bytes(32));"
CRON_SECRET=

# Musí obsahovať doménu, z ktorej beží UI — inak Sanctum SPA login nefunguje.
SANCTUM_STATEFUL_DOMAINS=event-api.local,localhost,localhost:5173,127.0.0.1,127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://event-api.local,http://localhost:5173,http://127.0.0.1:5173
SESSION_DOMAIN=event-api.local

APP_LOCALE=sk
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=sk_SK

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=event-api
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

BROADCAST_CONNECTION=log

# public = lokálny disk (storage/app/public). Prechod na S3 je len o prepnutí
# na "s3" a vyplnení AWS_* nižšie — v kóde sa nič meniť nemusí.
FILESYSTEM_DISK=public

# sync = joby (generovanie variantov obrázkov, odosielanie e-mailov) bežia
# priamo v HTTP requeste. Na produkcii radšej "database" + queue worker.
QUEUE_CONNECTION=sync

# Rate limitery ukladajú počítadlá do cache — cache musí byť funkčná.
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# S3 úložisko. Pre prechod na S3 vyplň kľúče nižšie a prepni FILESYSTEM_DISK=s3.
# AWS_URL = verejná doména na čítanie objektov (CloudFront alebo statická S3/website
# doména). Používa sa na generovanie verejných URL cez Storage::disk('s3')->url().
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Platené API. Používajú ho AI endpointy (detect-from-text, improve-text,
# venues/detect, tools/ai-detector) aj scheduler cez app:ai-detector.
OPENAI_API_KEY=

# Sociálne prihlásenie (voliteľné).
# GOOGLE_CLIENT_ID=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# Účet, ktorý založí DatabaseSeeder ako super-admina.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Zapína AI detekciu kanála pri importe podujatí (každý import stojí peniaze).
IMPORTS_DETECT_CANAL_WITH_AI=true

# Popisy nových kanálov/miest z importu píše AI (inak neutrálny fallback).
# Ak nie je nastavené, preberá hodnotu IMPORTS_DETECT_CANAL_WITH_AI.
IMPORTS_DESCRIBE_WITH_AI=true

# Externá služba pre PdfConverterService (import príloh z PDF).
PDF_CONVERTER_URL=
PDF_CONVERTER_TOKEN=

# -----------------------------------------------------------------------------
# Voliteľné ladenie správania. Nižšie sú uvedené defaulty z config/ — odkomentuj
# len to, čo chceš zmeniť.
# -----------------------------------------------------------------------------

# Zdroje pre app:import-event-sources (čiarkou oddelený zoznam) a koľko strán
# stránkovania sa z každého zdroja prejde.
# IMPORT_SOURCE_URLS=https://www.ecav.sk/aktuality/pozvanky,https://www.tkkbs.sk/search.php?rstext=pozvanka&rskde=tsl,https://www.vyveska.sk/zoznam-podujati/najnovsie/
# IMPORT_SOURCE_MAX_PAGES=1
# IMPORTS_USER_AGENT="${APP_NAME}"

# Koľko hodín má účastník na potvrdenie účasti, kým mu miesto prepadne.
# TICKET_CONFIRMATION_HOURS=48
# TICKET_WAITLIST_CONFIRMATION_HOURS=24

# Geokódovanie cez OpenStreetMap. Nominatim vyžaduje identifikovateľný
# User-Agent s kontaktom — inak môže požiadavky blokovať.
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# NOMINATIM_USER_AGENT="${APP_NAME}"
# WIKIPEDIA_USER_AGENT="${APP_NAME}"

# OPENAI_REQUEST_TIMEOUT=30
# VENUE_DETECTION_ATTACH_MAX_BYTES=10485760
# MUNICIPALITY_RESOLVER_CACHE_TTL=86400

# Verejná URL pre súbory, ak sa líši od APP_URL (napr. CDN pred storage).
# FILESYSTEM_PUBLIC_URL="${APP_URL}"

# NA PRODUKCII (HTTPS) zapni bezpečnostné vlastnosti session cookie:
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
